# War Room — copy to `.env` and adjust (see README).
# Values below match `config.py` defaults when unset.

# Ollama / OpenAI-compatible inference
LOCAL_MODEL=ollama/llama3.1:8b
DAILY_DRIVER_BUYER_MODEL=ollama/llama3.3:60b
LOCAL_BASE_URL=http://localhost:11434

# ChromaDB
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=pm_tools
RAG_RESULTS_PER_QUERY=5

# Swarm
MAX_SCOUTS=20
MAX_WORKERS=10

# API server (uvicorn)
API_HOST=0.0.0.0
API_PORT=8000

# Optional — video ingestion & screenshot pipelines only
# OPENAI_API_KEY=
