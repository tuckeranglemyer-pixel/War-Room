# War Room — copy to `.env` and adjust (see README).
# Values below match `config.py` defaults when unset.

# Multi-model defaults (DGX Spark target)
FIRST_TIMER_MODEL=ollama/llama3.3:70b
DAILY_DRIVER_MODEL=ollama/qwen3:32b
BUYER_MODEL=ollama/mistral-small:24b

# Adaptive fallback (thermal-constrained hardware)
FALLBACK_MODEL=ollama/qwen3:32b
WAR_ROOM_MODEL=ollama/qwen3:32b

# Infrastructure
LOCAL_BASE_URL=http://localhost:11434
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=pm_tools
API_PORT=8000
MAX_SCOUTS=20
THERMAL_CEILING=70
THERMAL_RESUME=55
COOLDOWN_SECONDS=30
MAX_CONTEXT_CHARS=8000

# Optional (video ingestion only)
OPENAI_API_KEY=sk-your-key-here
